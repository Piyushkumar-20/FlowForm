{
   "extends": "../../packages/typescript-config/nextjs.json",

  "compilerOptions": {
    "baseUrl": ".",

    "paths": {
      "~/*": ["./*"]
    },

    "moduleResolution": "bundler",

    "ignoreDeprecations": "5.0",

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],

  "exclude": ["node_modules"]
}